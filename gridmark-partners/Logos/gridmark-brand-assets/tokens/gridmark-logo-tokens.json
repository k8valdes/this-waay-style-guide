{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "gridmark": {
    "logo": {
      "color": {
        "structure-on-light": { "$type": "color", "$value": "#0C2A48", "$description": "Mark linework on light grounds (Deep Navy)" },
        "structure-on-dark":  { "$type": "color", "$value": "#FFFFFF", "$description": "Mark linework reversed on Deep Navy" },
        "structure-premium":  { "$type": "color", "$value": "#C8A46B", "$description": "All-brass variant, Deep Navy grounds only" },
        "marked-cell":        { "$type": "color", "$value": "#C8A46B", "$description": "The brass marked cell — constant across all variants" }
      },
      "geometry": {
        "viewbox":            { "$type": "dimension", "$value": "260x220", "$description": "Master mark artboard units" },
        "cell":               { "$type": "dimension", "$value": "26x13", "$description": "Marked cell size in artboard units; the clear-space unit" },
        "stroke-structure":   { "$type": "number", "$value": 6,   "$description": "Tower legs" },
        "stroke-portal":      { "$type": "number", "$value": 4.6, "$description": "Portal beam" },
        "stroke-deck":        { "$type": "number", "$value": 5,   "$description": "Deck chord (bottom)" },
        "stroke-brace":       { "$type": "number", "$value": 2.4, "$description": "Tower X-brace" },
        "stroke-detail":      { "$type": "number", "$value": 1.3, "$description": "Slot windows, deck posts" },
        "terminals":          { "$type": "string", "$value": "square", "$description": "All strokes use square linecaps" }
      },
      "usage": {
        "clear-space":        { "$type": "string", "$value": "1 marked cell on all sides" },
        "min-size-full":      { "$type": "dimension", "$value": "40px", "$description": "Below this width use the favicon cut" },
        "min-size-favicon":   { "$type": "dimension", "$value": "16px" },
        "mark-to-cap-ratio":  { "$type": "number", "$value": 2.4, "$description": "Mark height = GRIDMARK cap height x 2.4 in horizontal lockup" }
      }
    },
    "wordmark": {
      "font-family":      { "$type": "fontFamily", "$value": ["Axiforma", "Poppins", "Segoe UI", "sans-serif"] },
      "name-weight":      { "$type": "fontWeight", "$value": 600 },
      "name-tracking":    { "$type": "dimension", "$value": "0.14em" },
      "descriptor-weight":{ "$type": "fontWeight", "$value": 400 },
      "descriptor-scale": { "$type": "number", "$value": 0.4, "$description": "PARTNERS font-size = GRIDMARK size x 0.4; letters justified to name width" },
      "rule":             { "$type": "string", "$value": "1px hairline, 55% opacity, terminates in one brass cell flush right" },
      "tagline-color":    { "$type": "color", "$value": "#0D698A", "$description": "Steel; sentence case; Regular" }
    }
  }
}
